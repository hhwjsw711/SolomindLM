# ============================================
# Staging Environment Variables
# ============================================
# Copy this file to .env.staging and fill in values
# Used for local testing against staging deployment

# ============================================
# CONVEX STAGING (Required)
# ============================================
CONVEX_DEPLOY_KEY_STAGING=your_staging_deploy_key
VITE_CONVEX_URL_STAGING=https://your-staging-deployment.convex.cloud

# ============================================
# CONVEX PRODUCTION (for reference)
# ============================================
# Keep these commented out to avoid confusion
# CONVEX_DEPLOYMENT=dev:your-project-name
# CONVEX_URL=https://your-project.convex.cloud
# CONVEX_SITE_URL=https://your-project.convex.site

# ============================================
# EXTERNAL SERVICES (same as production)
# ============================================
# Copy values from your .env file
# STRIPE_SECRET_KEY=
# TAVILY_API_KEY=
# TOGETHER_AI_API_KEY=
# etc.

# ============================================
# LOCAL DEV
# ============================================
SITE_URL=http://localhost:5173
