{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "RAILPACK",
    "buildCommand": "pnpm install && pnpm --filter @solomindlm/api build:worker",
    "watchPatterns": ["apps/api/**"],
    "packageManager": "pnpm"
  },
  "deploy": {
    "startCommand": "node dist/utils/worker.js",
    "healthcheckPath": "/",
    "healthcheckTimeout": 300,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10,
    "numReplicas": 2,
    "multiRegionConfig": {
      "us-west2": {
        "numReplicas": 2
      }
    }
  },
  "rootDirectory": "apps/api"
}
